<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Little Rip needs microphone access to hear you speak. Audio stays on your device.</string>
    
    <!-- Speech recognition -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Little Rip uses speech recognition to understand what you say. All processing happens on-device.</string>
    
    <!-- Bluetooth -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Little Rip uses Bluetooth to connect to external microphones and speakers for a hands-free experience.</string>
    
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Little Rip uses Bluetooth to connect to external microphones and speakers.</string>
    
    <!-- Background audio (so it keeps listening/speaking in background) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>bluetooth-central</string>
    </array>
    
    <!-- App info -->
    <key>CFBundleDisplayName</key>
    <string>Little Rip</string>
    
    <key>CFBundleIdentifier</key>
    <string>com.little-rip.app</string>
    
    <key>CFBundleVersion</key>
    <string>1.0</string>
    
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    
    <key>MinimumOSVersion</key>
    <string>17.0</string>
    
    <key>UILaunchScreen</key>
    <dict/>
    
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>